// Neth ERP System - Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
  ACCOUNTANT
  WAREHOUSE_STAFF
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  QR_CODE
  CHEQUE
  GIFT_CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
  RETURNED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RETURN
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

// ============ USER MANAGEMENT ============

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  phoneNumber   String?
  avatar        String?
  role          UserRole @default(CASHIER)
  status        UserStatus @default(ACTIVE)
  branchId      String?
  branch        Branch?   @relation("BranchUsers", fields: [branchId], references: [id], onDelete: SetNull)
  
  lastLogin     DateTime?
  loginAttempts Int       @default(0)
  lockUntil     DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  
  refreshTokens RefreshToken[]
  activityLogs  ActivityLog[]
  auditLogs     AuditLog[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([branchId])
  @@index([email])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  action    String
  details   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AuditLog {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  action          AuditAction
  tableName       String
  recordId        String
  changes         Json?
  previousValues  Json?
  newValues       Json?
  ipAddress       String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([tableName])
  @@index([recordId])
  @@index([createdAt])
}

// ============ ORGANIZATION & BRANCHES ============

model Branch {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  address         String
  city            String
  state           String
  zipCode         String
  country         String
  phoneNumber     String
  email           String
  manager         String?
  warehouseId     String?
  warehouse       Warehouse? @relation("BranchWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)
  
  users           User[]    @relation("BranchUsers")
  bankAccounts    BankAccount[] @relation("BranchBankAccounts")
  inventories     Inventory[]
  sales           Sale[]
  purchases       Purchase[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([warehouseId])
}

model Warehouse {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  address         String
  capacity        Float    @default(0)
  usedCapacity    Float    @default(0)
  branches        Branch[]  @relation("BranchWarehouse")
  
  inventoryItems  InventoryItem[]
  stockTransfers  StockTransfer[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
}

// ============ PRODUCT MANAGEMENT ============

model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  barcode         String?  @unique
  name            String
  description     String?
  categoryId      String
  category        ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId         String?
  brand           Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  
  costPrice       Float
  sellingPrice    Float
  profitMargin    Float
  tax             Float    @default(0)
  
  unitId          String
  unit            Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)
  
  imageUrl        String?
  hasVariants     Boolean  @default(false)
  active          Boolean  @default(true)
  
  variants        ProductVariant[]
  prices          ProductPrice[]
  inventories     Inventory[]
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([sku])
  @@index([active])
}

model ProductCategory {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  parent          ProductCategory? @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  parentId        String?
  
  subCategories   ProductCategory[] @relation("SubCategories")
  products        Product[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([parentId])
}

model Brand {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  logo            String?
  
  products        Product[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
}

model Unit {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  symbol          String
  
  products        Product[]
  
  createdAt       DateTime  @default(now())

  @@index([code])
}

model ProductVariant {
  id              String   @id @default(cuid())
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  name            String
  sku             String   @unique
  barcode         String?  @unique
  
  costPrice       Float
  sellingPrice    Float
  
  active          Boolean  @default(true)
  
  inventories     Inventory[] @relation("VariantInventories")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([productId])
  @@index([sku])
}

model ProductPrice {
  id              String   @id @default(cuid())
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  priceLevel      Int      @default(1)
  price           Float
  minQuantity     Float    @default(1)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([productId, priceLevel, minQuantity])
  @@index([productId])
}

// ============ INVENTORY MANAGEMENT ============

model Inventory {
  id              String   @id @default(cuid())
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId        String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  warehouseId     String
  variant         ProductVariant? @relation("VariantInventories", fields: [variantId], references: [id], onDelete: SetNull)
  variantId       String?
  
  quantity        Float    @default(0)
  reservedQty     Float    @default(0)
  availableQty    Float    @default(0)
  minStock        Float    @default(0)
  maxStock        Float    @default(0)
  
  batch           String?
  expiryDate      DateTime?
  
  movements       StockMovement[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([productId, branchId, warehouseId, variantId, batch])
  @@index([productId])
  @@index([branchId])
  @@index([warehouseId])
}

model StockMovement {
  id              String   @id @default(cuid())
  inventory       Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  inventoryId     String
  
  type            StockMovementType
  quantity        Float
  reason          String?
  reference       String?
  
  saleItem        SaleItem? @relation("SaleItemMovements", fields: [saleItemId], references: [id], onDelete: SetNull)
  saleItemId      String?
  
  purchaseItem    PurchaseItem? @relation("PurchaseItemMovements", fields: [purchaseItemId], references: [id], onDelete: SetNull)
  purchaseItemId  String?
  
  createdAt       DateTime  @default(now())

  @@index([inventoryId])
  @@index([type])
  @@index([createdAt])
}

model StockTransfer {
  id              String   @id @default(cuid())
  referenceNo     String   @unique
  fromWarehouse   Warehouse @relation(fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  fromWarehouseId String
  toWarehouse     Warehouse? @relation(fields: [toWarehouseId], references: [id], onDelete: SetNull)
  toWarehouseId   String?
  
  status          OrderStatus @default(PENDING)
  items           StockTransferItem[]
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([fromWarehouseId])
  @@index([status])
}

model StockTransferItem {
  id              String   @id @default(cuid())
  transfer        StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  transferId      String
  
  product         Product  @relation(fields: [productId], references: [id])
  productId       String
  quantity        Float
  receivedQty     Float    @default(0)
  
  createdAt       DateTime  @default(now())

  @@index([transferId])
  @@index([productId])
}

// ============ CUSTOMER MANAGEMENT ============

model Customer {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  email           String?
  phoneNumber     String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String?
  
  type            String   @default("RETAIL")
  taxId           String?
  creditLimit     Float    @default(0)
  currentDebt     Float    @default(0)
  loyaltyPoints   Float    @default(0)
  
  groupId         String?
  group           CustomerGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  
  notes           String?
  active          Boolean  @default(true)
  
  sales           Sale[]
  payments        Payment[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([email])
  @@index([active])
}

model CustomerGroup {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  discountPercent Float    @default(0)
  
  customers       Customer[]
  
  createdAt       DateTime  @default(now())

  @@index([code])
}

// ============ SUPPLIER MANAGEMENT ============

model Supplier {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  email           String?
  phoneNumber     String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String?
  
  taxId           String?
  bankDetails     String?
  creditLimit     Float    @default(0)
  currentBalance  Float    @default(0)
  
  notes           String?
  active          Boolean  @default(true)
  
  purchases       Purchase[]
  payments        SupplierPayment[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([active])
}

// ============ SALES MANAGEMENT ============

model Sale {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  branchId        String
  
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId      String?
  
  status          InvoiceStatus @default(DRAFT)
  saleType        String   @default("REGULAR")
  
  subTotal        Float
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float
  paidAmount      Float    @default(0)
  dueAmount       Float
  
  items           SaleItem[]
  payments        Payment[]
  returns         SaleReturn[]
  
  notes           String?
  printCount      Int      @default(0)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([branchId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id              String   @id @default(cuid())
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId          String
  
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId       String
  
  quantity        Float
  unitPrice       Float
  discount        Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  lineTotal       Float
  
  batch           String?
  expiryDate      DateTime?
  
  movements       StockMovement[] @relation("SaleItemMovements")
  
  createdAt       DateTime  @default(now())

  @@index([saleId])
  @@index([productId])
}

model SaleReturn {
  id              String   @id @default(cuid())
  returnNumber    String   @unique
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Restrict)
  saleId          String
  
  quantity        Float
  reason          String
  refundAmount    Float
  
  createdAt       DateTime  @default(now())

  @@index([saleId])
}

model Payment {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId          String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  customerId      String
  
  method          PaymentMethod
  amount          Float
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([saleId])
  @@index([customerId])
  @@index([status])
}

// ============ PURCHASE MANAGEMENT ============

model Purchase {
  id              String   @id @default(cuid())
  poNumber        String   @unique
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  branchId        String
  
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId      String
  
  status          OrderStatus @default(PENDING)
  
  subTotal        Float
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float
  paidAmount      Float    @default(0)
  dueAmount       Float
  
  items           PurchaseItem[]
  payments        SupplierPayment[]
  returns         PurchaseReturn[]
  
  notes           String?
  expectedDate    DateTime?
  receivedDate    DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([branchId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
}

model PurchaseItem {
  id              String   @id @default(cuid())
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseId      String
  
  product         Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId       String
  
  quantity        Float
  receivedQty     Float    @default(0)
  unitPrice       Float
  discount        Float    @default(0)
  discountPercent Float    @default(0)
  taxAmount       Float    @default(0)
  lineTotal       Float
  
  batch           String?
  expiryDate      DateTime?
  
  movements       StockMovement[] @relation("PurchaseItemMovements")
  
  createdAt       DateTime  @default(now())

  @@index([purchaseId])
  @@index([productId])
}

model PurchaseReturn {
  id              String   @id @default(cuid())
  returnNumber    String   @unique
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  purchaseId      String
  
  quantity        Float
  reason          String
  refundAmount    Float
  
  createdAt       DateTime  @default(now())

  @@index([purchaseId])
}

model SupplierPayment {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  purchase        Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  purchaseId      String?
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierId      String
  
  method          PaymentMethod
  amount          Float
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([purchaseId])
  @@index([supplierId])
  @@index([status])
}

// ============ ACCOUNTING SYSTEM ============

model BankAccount {
  id              String   @id @default(cuid())
  code            String   @unique
  accountName     String
  accountNumber   String   @unique
  bankName        String
  branch          Branch   @relation("BranchBankAccounts", fields: [branchId], references: [id], onDelete: Cascade)
  branchId        String
  
  balance         Float    @default(0)
  currency        String   @default("USD")
  
  transactions    BankTransaction[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([code])
  @@index([branchId])
}

model BankTransaction {
  id              String   @id @default(cuid())
  bankAccount     BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId       String
  
  type            TransactionType
  amount          Float
  description     String
  referenceNo     String?
  
  createdAt       DateTime  @default(now())

  @@index([accountId])
  @@index([type])
  @@index([createdAt])
}

model JournalEntry {
  id              String   @id @default(cuid())
  entryNumber     String   @unique
  description     String
  reference       String?
  
  totalDebit      Float    @default(0)
  totalCredit     Float    @default(0)
  
  status          TransactionStatus @default(PENDING)
  
  entries         JournalLine[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([entryNumber])
  @@index([status])
}

model JournalLine {
  id              String   @id @default(cuid())
  entry           JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryId         String
  account         String
  debit           Float    @default(0)
  credit          Float    @default(0)
  
  createdAt       DateTime  @default(now())

  @@index([entryId])
}

model FinancialReport {
  id              String   @id @default(cuid())
  type            String   // P&L, Balance Sheet, Trial Balance
  period          String   // YYYY-MM format
  data            Json
  
  createdAt       DateTime  @default(now())

  @@unique([type, period])
  @@index([type])
}

// ============ NOTIFICATIONS ============

model Notification {
  id              String   @id @default(cuid())
  type            String   // LOW_STOCK, PAYMENT_DUE, etc.
  title           String
  message         String
  recipientId     String?
  
  channel         NotificationChannel @default(IN_APP)
  status          NotificationStatus @default(PENDING)
  
  sentAt          DateTime?
  readAt          DateTime?
  
  createdAt       DateTime  @default(now())

  @@index([recipientId])
  @@index([status])
  @@index([type])
}

model EmailQueue {
  id              String   @id @default(cuid())
  to              String
  subject         String
  body            String
  status          NotificationStatus @default(PENDING)
  attempts        Int      @default(0)
  lastError       String?
  
  sentAt          DateTime?
  
  createdAt       DateTime  @default(now())

  @@index([status])
}

// ============ SYSTEM SETTINGS ============

model SystemSetting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String
  type            String   // string, number, boolean, json
  description     String?
  
  updatedAt       DateTime  @updatedAt
}

model DailyClosing {
  id              String   @id @default(cuid())
  closingDate     DateTime @unique
  totalSales      Float
  totalRefunds    Float
  totalPurchases  Float
  cashOnHand      Float
  status          String   @default("OPEN")
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([closingDate])
}

model Quotation {
  id              String   @id @default(cuid())
  quotationNumber String   @unique
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId      String?
  
  items           QuotationItem[]
  subTotal        Float
  taxAmount       Float    @default(0)
  discountAmount  Float    @default(0)
  totalAmount     Float
  
  status          String   @default("DRAFT")
  expiryDate      DateTime?
  notes           String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([customerId])
  @@index([status])
}

model QuotationItem {
  id              String   @id @default(cuid())
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId     String
  
  product         Product  @relation(fields: [productId], references: [id])
  productId       String
  
  quantity        Float
  unitPrice       Float
  discount        Float    @default(0)
  discountPercent Float    @default(0)
  lineTotal       Float
  
  createdAt       DateTime  @default(now())

  @@index([quotationId])
}
